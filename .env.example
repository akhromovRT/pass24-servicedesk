DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pass24_servicedesk
SECRET_KEY=change-me-in-production
APP_BASE_URL=https://support.pass24pro.ru

# SMTP (support@pass24online.ru)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=support@pass24online.ru
SMTP_PASSWORD=your-email-password-here
SMTP_FROM=support@pass24online.ru
SMTP_USE_SSL=true

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Reverse-proxy base for Bot API. Leave empty to use api.telegram.org directly.
# Required on hosts where outbound TCP to 149.154.160.0/20 is blocked.
# Example: http://45.82.15.28:8080/telegram
TELEGRAM_API_BASE=
