DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pass24_servicedesk
SECRET_KEY=change-me-in-production
APP_BASE_URL=https://support.pass24pro.ru

# SMTP (support@pass24online.ru)
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=support@pass24online.ru
SMTP_PASSWORD=your-email-password-here
SMTP_FROM=support@pass24online.ru
SMTP_USE_SSL=true

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Reverse-proxy base for Bot API. Leave empty to use api.telegram.org directly.
# Required on hosts where outbound TCP to 149.154.160.0/20 is blocked, or when
# using self-hosted telegram-bot-api (see agent_docs/guides/telegram-bot-api-self-hosted.md).
# Examples:
#   http://45.82.15.28:8080/telegram  (reverse-proxy for cloud Bot API)
#   http://178.104.228.43             (self-hosted telegram-bot-api --local)
TELEGRAM_API_BASE=
# File download base for self-hosted telegram-bot-api in --local mode.
# getFile returns absolute FS paths (/var/lib/telegram-bot-api/...); this base
# replaces that prefix for HTTP download (e.g. Caddy file_server).
# Empty → defaults to {TELEGRAM_API_BASE}/tgfiles.
TELEGRAM_FILE_API_BASE=
